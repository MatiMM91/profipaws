# Profipaws Frontend
VITE_API_URL=http://localhost:8000

# Google OAuth (client-side)
VITE_GOOGLE_CLIENT_ID=

# Stripe (publishable key for Checkout / Elements)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Set true on production to lock public access (owner can still sign in via backend allowlist)
VITE_MAINTENANCE_MODE=false
